# ── Email (Resend) ─────────────────────────────────────────────────────
# Get a free key at https://resend.com — free tier: 3,000 emails/month
RESEND_API_KEY=re_xxxxxxxxxxxxxxxx

# Who to send alert emails to (comma-separated)
NOTIFY_EMAILS=you@example.com,colleague@example.com

# The "from" address (must be a verified domain in Resend)
EMAIL_FROM=alerts@yourdomain.com


# ── Cron security ──────────────────────────────────────────────────────
# Protects /api/check-updates from public access.
# Generate with: openssl rand -hex 32
CRON_SECRET=your-secret-here


# ── Storage (Vercel KV — optional, production only) ───────────────────
# Run `vercel env pull` after linking a KV database to populate these.
# Without them, a local .seen-updates.json file is used instead.
# KV_REST_API_URL=
# KV_REST_API_TOKEN=


# ── Development ────────────────────────────────────────────────────────
# Set to "true" to use mock incident data instead of the live Google API.
# Useful when developing without network access or to see all card states.
NEXT_PUBLIC_USE_MOCK=false


# ── Web Push (VAPID) — optional, enables push when tab is closed ──────
# Generate keys (run once):
#   node -e "const {generateVAPIDKeys}=require('web-push'); const k=generateVAPIDKeys(); console.log('VAPID_PUBLIC_KEY='+k.publicKey); console.log('VAPID_PRIVATE_KEY='+k.privateKey);"
#
# npm i web-push @types/web-push
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:admin@yourdomain.com
